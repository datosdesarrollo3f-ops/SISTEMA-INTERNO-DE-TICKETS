# =========================================================================
# CONFIGURACIÓN DE SUPABASE - SISTEMA INTERNO
# =========================================================================
# NOTA: Para el script de Python local, copia este archivo y renombralo como ".env"
# en esta misma carpeta, rellenando los valores reales de tu proyecto de Supabase.

# 1. URL del Proyecto (Project URL)
# Encontralo en Supabase: Settings (Engranaje) > API > Project URL
SUPABASE_URL=https://tu-proyecto-id.supabase.co

# 2. Clave Pública Anon (Anon Public Key)
# Encontralo en Supabase: Settings (Engranaje) > API > Project API Keys > anon public
SUPABASE_KEY=tu-clave-anon-key-larga-aqui

# =========================================================================
# CONFIGURACIÓN PARA EL DESPLIEGUE EN VERCEL
# =========================================================================
# Cuando despliegues la web en Vercel, agrega estas variables en la seccion 
# "Environment Variables" de la configuracion del proyecto:
#
# - Nombre: VITE_SUPABASE_URL   Valor: (Tu URL de Supabase)
# - Nombre: VITE_SUPABASE_KEY   Valor: (Tu Clave Anon de Supabase)
# =========================================================================
